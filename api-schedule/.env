QUERY_UPDATE_PAIR='UPDATE pair SET dayofweekid=$1, teachersubjectid=$2, audienceid=$3, datestart=$4, numberweeks=$5, groupid=$6, typeofpairid=$7, timeid=$8 where id=$9 RETURNING *'

